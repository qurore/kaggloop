{
  "env": {
    "PYTHONUNBUFFERED": "1",
    "KLOOP_AUTOPILOT": "0",
    "KLOOP_AUTOPILOT_MAX": "100",
    "KLOOP_MAX_ITERATIONS": "100",
    "KLOOP_MAX_SUBAGENTS": "12",
    "KLOOP_COLAB_QUEUE": "/Users/ryshiro/Library/CloudStorage/GoogleDrive-ry.shiroshita@gmail.com/My Drive/kaggloop/queue",
    "KLOOP_COLAB_RESULTS": "/Users/ryshiro/Library/CloudStorage/GoogleDrive-ry.shiroshita@gmail.com/My Drive/kaggloop/results",
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
  },
  "permissions": {
    "allow": [
      "Bash(python -m kloop.project:*)",
      "Bash(python -m kloop.ledger:*)",
      "Bash(python -m kloop.smallstart:*)",
      "Bash(python -m kloop.gate:*)",
      "Bash(python -m kloop.journal:*)",
      "Bash(python -m kloop.selfimprove:*)",
      "Bash(python -m kloop.kaggle list:*)",
      "Bash(python -m kloop.kaggle files:*)",
      "Bash(python -m kloop.kaggle kernels:*)",
      "Bash(python -m kloop.kaggle leaderboard:*)",
      "Bash(python -m kloop.kaggle submissions:*)",
      "Bash(python -m kloop.colab status:*)",
      "Bash(python -m kloop.colab ingest:*)",
      "Bash(python -m kloop.score:*)",
      "Bash(.venv/bin/python -m kloop.project:*)",
      "Bash(.venv/bin/python -m kloop.ledger:*)",
      "Bash(.venv/bin/python -m kloop.smallstart:*)",
      "Bash(.venv/bin/python -m kloop.gate:*)",
      "Bash(.venv/bin/python -m kloop.journal:*)",
      "Bash(.venv/bin/python -m kloop.selfimprove:*)",
      "Bash(.venv/bin/python -m kloop.colab status:*)",
      "Bash(.venv/bin/python -m kloop.score:*)",
      "Bash(bash scripts/doctor.sh)",
      "Edit(.claude/skills/**)",
      "Write(.claude/skills/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/hooks/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_experiment_exec.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_submission.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_tool_use.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop_autopilot.py\""
          }
        ]
      }
    ]
  }
}
