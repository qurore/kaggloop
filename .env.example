# Copy to .env and adjust. The hooks/helpers read these from the environment.
# (.env is gitignored. Claude Code does not auto-load .env — `source .env` in a shell,
#  or set these in .claude/settings.json "env", to apply them.)

# --- Autopilot (Stop hook) ---
# 1 = drive the loop hands-off after a competition is selected; 0 = pause between
# stages (default). The human always picks the competition regardless of this.
KLOOP_AUTOPILOT=0
# Per-session cap on auto-advances before the Stop hook forces a check-in.
KLOOP_AUTOPILOT_MAX=10
# How many full hypothesize->experiment->submit loops the autopilot may run.
KLOOP_MAX_ITERATIONS=3

# --- Colab compute bridge (shared, Drive-synced folders) ---
# Point these at the same folder the Colab worker mounts (see colab/README.md).
# KLOOP_COLAB_QUEUE="$HOME/Library/CloudStorage/GoogleDrive-<you>/My Drive/kaggloop/queue"
# KLOOP_COLAB_RESULTS="$HOME/Library/CloudStorage/GoogleDrive-<you>/My Drive/kaggloop/results"

# --- Kaggle API ---
# The kaggle CLI reads ~/.kaggle/kaggle.json by default; alternatively set these.
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# --- Science MCP (optional) ---
# Semantic Scholar works without a key; a key raises rate limits.
# SEMANTIC_SCHOLAR_API_KEY=
